# =============================================================================
# MHA - Bureau de Suivi · Variables d'environnement (modele)
# Copier vers .env et completer. .env est ignore par git.
# =============================================================================

# --- PostgreSQL (Render fournit DATABASE_URL automatiquement en prod) ---
DATABASE_URL=postgresql://localhost:5432/mha_bs
PGSSLMODE=prefer

# --- Server ---
NODE_ENV=development
PORT=3001
PUBLIC_URL=http://localhost:5173

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- JWT (interne) ---
JWT_ACCESS_SECRET=changeMeWithLongRandomString
JWT_REFRESH_SECRET=changeMeWithAnotherLongRandomString
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# --- API key externe ---
EXTERNAL_API_ENABLED=true

# --- Bootstrap (premier admin) ---
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_EMAIL=admin@mha.sn
BOOTSTRAP_ADMIN_PASSWORD=changeMeOnFirstLogin
BOOTSTRAP_ADMIN_FULLNAME=Administrateur MHA

# --- Mail (Resend) ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxx
MAIL_FROM=Bureau de Suivi MHA <noreply@mha.sn>
MAIL_REPLY_TO=bs@mha.sn

# --- Stockage fichiers (disque persistant Render) ---
UPLOADS_DIR=./uploads
UPLOADS_MAX_BYTES=20971520

# --- Logs ---
LOG_LEVEL=info

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=200
RATE_LIMIT_LOGIN_MAX=5
